<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ForexActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_gradient_dark"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#DDF4E4"
            app:cardCornerRadius="14dp"
            android:layout_marginBottom="16dp"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/tvForexDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tanggal dan Waktu: Loading..."
                android:textColor="#2E5A44"
                android:textSize="15sp"
                android:gravity="center"
                android:padding="18dp" />
        </androidx.cardview.widget.CardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvForex"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical"/>

    </LinearLayout>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>