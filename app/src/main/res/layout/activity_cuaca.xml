<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_weather">

    <EditText
        android:id="@+id/etKota"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:hint="Masukkan nama kota"
        android:textColor="#FFFFFF"
        android:textColorHint="#888888"
        android:inputType="textCapWords"
        android:backgroundTint="#CCCCCC"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/btnTampilkan"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btnTampilkan"
        android:layout_width="wrap_content"
        android:layout_height="50dp"
        android:text="TAMPILKAN"
        android:backgroundTint="#03A9F4"
        android:textColor="#FFFFFF"
        app:cornerRadius="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#1565C0"
        app:layout_constraintTop_toBottomOf="@+id/etKota">

        <TextView
            android:id="@+id/tvInfoKota"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"
            android:gravity="center" />
    </LinearLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@+id/headerLayout"
        app:layout_constraintBottom_toTopOf="@+id/tvTotalRecord">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCuaca"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <TextView
        android:id="@+id/tvTotalRecord"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total Record : 0"
        android:background="#1565C0"
        android:padding="10dp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent" />

    <WebView
        android:id="@+id/webViewMaps"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@+id/headerLayout"
        app:layout_constraintBottom_toTopOf="@+id/btnBack" />

    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="KEMBALI KE LIST CUACA"
        android:backgroundTint="#FF5722"
        android:textColor="#FFFFFF"
        android:visibility="gone"
        app:cornerRadius="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>